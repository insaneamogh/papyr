# Environment variables for Papyr Backend

# --- OpenAI Configuration ---
# API key used by the fetch_arxiv.py script to generate Micro-Tasks from paper abstracts.
OPENAI_API_KEY=sk-your-openai-api-key-here

# --- Database Configuration ---
# Optional: SQLite Database URI where papers and tasks are stored. 
# Defaults to sqlite:///./papyr.db if not provided.
DATABASE_URL=sqlite:///./papyr.db

# --- API Configuration ---
# Optional: The port the FastAPI server runs on (default: 8000)
# PORT=8000
